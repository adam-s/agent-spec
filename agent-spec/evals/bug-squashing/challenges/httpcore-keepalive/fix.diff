diff --git a/httpcore/_async/connection_pool.py b/httpcore/_async/connection_pool.py
index 96e973d..5ef74e6 100644
--- a/httpcore/_async/connection_pool.py
+++ b/httpcore/_async/connection_pool.py
@@ -291,7 +291,7 @@ class AsyncConnectionPool(AsyncRequestInterface):
                 closing_connections.append(connection)
             elif (
                 connection.is_idle()
-                and len([connection.is_idle() for connection in self._connections])
+                and sum(connection.is_idle() for connection in self._connections)
                 > self._max_keepalive_connections
             ):
                 # log: "closing idle connection"
